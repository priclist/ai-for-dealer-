# Ironman AI — Backend Adapter Configuration
# Copy this file to .env and fill in your values

# OpenClaw Gateway URL (default: http://127.0.0.1:18789)
GATEWAY_URL=http://127.0.0.1:18789

# OpenClaw Gateway API token (required)
GATEWAY_TOKEN=your-token-here

# Model to use (default: openclaw)
GATEWAY_MODEL=openclaw

# Server port (default: 3101)
PORT=3101
